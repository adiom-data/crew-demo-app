{
  "addr": ":8080",
  "auth": {
    "issuer": "http://crew-demo-api/auth"
  },
  "backends": [
    {
      "name": "crew-demo-api",
      "url": "http://crew-demo-api",
      "auth_forwarding": "verified_bearer",
      "routes": [
        {
          "path": "/sample.v1.SampleService/"
        },
        {
          "path": "/sample.v1.PartnerService/"
        },
        {
          "path": "/sample.v1.OnboardingService/",
          "public": true
        },
        {
          "path": "/adiom.auth.v1.AuthService/",
          "public": true
        },
        {
          "path": "/auth/",
          "public": true
        }
      ]
    }
  ],
  "spas": [
    {
      "path": "/",
      "dir": "/app/web/dist"
    }
  ]
}
